# ============================================
# Factory MES - Environment Variables
# ============================================
# For local development, copy this file to .env
# For Railway deployment, these are set via Railway Dashboard or .env file

# ----- Database -----
# Local (SQLite):
# DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL):
# Railway provides this automatically when you add the PostgreSQL plugin.
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/factory_mes"

# ----- Next Auth (optional) -----
# For session encryption in production
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="https://your-app.railway.app"
